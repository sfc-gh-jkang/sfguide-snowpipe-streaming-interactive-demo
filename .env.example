# =============================================================================
# Demo configuration — copy to .env and fill in. NEVER commit .env to git.
# =============================================================================
# All scripts and the Streamlit app read from these. Set them once here
# instead of editing every file individually.

# -----------------------------------------------------------------------------
# Snowflake
# -----------------------------------------------------------------------------
# Your `snow connection list` connection name (the one with ACCOUNTADMIN)
SNOWFLAKE_CONNECTION=<your-connection>

# Snowflake account locator (from `snow connection list` -> "account")
SNOWFLAKE_ACCOUNT=<your-snowflake-account>

# -----------------------------------------------------------------------------
# GCP VM (Snowpipe Streaming HPA producer host)
# -----------------------------------------------------------------------------
VM_NAME=<your-vm-name>
VM_ZONE=us-central1-c
# Static NAT IP of the VM (used for the network-policy CIDR allow-list)
VM_STATIC_IP=<your-vm-static-ip>

# -----------------------------------------------------------------------------
# Cloudflare tunnel
# -----------------------------------------------------------------------------
# Public DNS hostname routed to VM:8080 via cloudflared (e.g. ingest.example.com)
INGEST_TUNNEL_HOST=<your-tunnel-host>

# Cloudflare Tunnel token (Path 1 — compose-embedded tunnel)
# Create a tunnel at https://one.dash.cloudflare.com → Networks → Tunnels,
# then paste the token here. Leave blank if using host-installed cloudflared (Path 2).
CLOUDFLARE_TUNNEL_TOKEN=<paste-from-cloudflare-dashboard>

# -----------------------------------------------------------------------------
# Ingest API key (rotate before any real traffic — generate a strong random)
# -----------------------------------------------------------------------------
INGEST_API_KEY=<set-a-strong-random-key>
