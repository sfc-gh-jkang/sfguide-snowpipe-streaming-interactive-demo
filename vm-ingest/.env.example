# VM Ingest Worker — Environment Variables
# Copy this to .env and fill in your values. NEVER commit .env to git.

# Snowflake connection
SNOWFLAKE_ACCOUNT=<your-snowflake-account>
SNOWFLAKE_USER=CREDIT_INGEST_USR
SNOWFLAKE_ROLE=CREDIT_INGEST_RL
SNOWFLAKE_DATABASE=SNOWFLAKE_EXAMPLE
SNOWFLAKE_SCHEMA=CREDIT_DEMO
SNOWFLAKE_TABLE=RAW_EVENTS
SNOWFLAKE_PRIVATE_KEY_PATH=/etc/credit/keys/credit_ingest.p8

# Ingest worker
PARTITION_COUNT=4
INGEST_API_KEY=<set-a-strong-random-key>

# OpenTelemetry (optional — for Observe.inc sidecar)
OTEL_SERVICE_NAME=credit-ingest
OTEL_EXPORTER_OTLP_ENDPOINT=http://observe-agent:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Observe tokens (optional — only if using observe-agent sidecar)
OBSERVE_TOKEN=<your-observe-token>
OBSERVE_COLLECTION_URL=<your-observe-collect-url>
OBSERVE_DATASTREAM_TOKEN=<your-observe-datastream-token>

# Cloudflare Tunnel (Path 1 — compose-embedded tunnel)
# Create a tunnel at https://one.dash.cloudflare.com → Networks → Tunnels,
# then paste the token here. Leave blank if using host-installed cloudflared (Path 2).
CLOUDFLARE_TUNNEL_TOKEN=<paste-from-cloudflare-dashboard>
